# Copy to .env.local and fill in. Never commit .env.local.

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin: must match Supabase Authentication → URL configuration →
# Site URL and Redirect URLs (e.g. https://your-domain.com and https://your-domain.com/auth/callback)
NEXT_PUBLIC_SITE_URL=

# Optional: server-only (Dashboard → Settings → API) — billing / admin
# SUPABASE_SERVICE_ROLE_KEY=
