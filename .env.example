# Copy to .env.local and fill in. Never commit .env.local.

# Supabase project (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin: must match Supabase Authentication → URL configuration →
# Site URL and Redirect URLs (e.g. https://your-domain.com and https://your-domain.com/auth/callback)
NEXT_PUBLIC_SITE_URL=

# Server-only — needed for generateLink (Resend path) and billing/admin
# Get from Supabase Dashboard → Settings → API
# SUPABASE_SERVICE_ROLE_KEY=

# Resend (resend.com) — enables in-app email delivery for password reset.
# Without these two, the app falls back to Supabase built-in mailer (rate-limited).
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@yourdomain.com
